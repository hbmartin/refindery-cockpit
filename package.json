{
  "name": "start-ui-web",
  "version": "4.0.0",
  "private": true,
  "description": "Opinionated TanStack Start starter",
  "homepage": "https://github.com/hbmartin/start-ui-web#readme",
  "bugs": {
    "url": "https://github.com/hbmartin/start-ui-web/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ivan Dalmet",
    "email": "ivan@dalmet.fr",
    "url": "https://github.com/ivan-dalmet"
  },
  "contributors": [
    {
      "name": "Yoann Fleury",
      "email": "yoannfleurydev@gmail.com",
      "url": "https://github.com/yoannfleurydev"
    },
    {
      "name": "Harold Martin",
      "email": "harold.martin@gmail.com",
      "url": "https://www.linkedin.com/in/harold-martin-98526971/"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hbmartin/start-ui-web.git"
  },
  "type": "module",
  "scripts": {
    "postinstall": "pnpm gen:build-info",
    "prepare": "pnpm lefthook install",
    "dev": "run-p env dev:*",
    "dev:app": "pnpm gen:build-info && vite dev",
    "build": "cross-env NODE_ENV=production run-p env gen:build-info && vite build",
    "start": "dotenv -- node .output/server/index.mjs",
    "env": "run-p env:*",
    "env:client": "dotenv -- node ./run-jiti ./src/platform/env/client.ts",
    "env:server": "dotenv -- node ./run-jiti ./scripts/validate-server-config.ts",
    "cosmos": "cosmos",
    "cosmos-export": "cosmos-export",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "format:changed": "node scripts/format-changed.mjs",
    "lint": "oxlint .",
    "lint:eslint": "eslint .",
    "lint:fix": "oxlint --fix .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "depcruise": "depcruise --config .dependency-cruiser.cjs src",
    "architecture:graph": "tsx scripts/generate-module-dependency-graph.ts",
    "architecture:graph:check": "tsx scripts/generate-module-dependency-graph.ts --check",
    "lint:sheriff": "sheriff verify",
    "check:test-layering": "node scripts/check-test-layering.mjs",
    "semgrep": "semgrep scan --config .semgrep.yml --error --quiet",
    "codeql:db": "mkdir -p test-results/codeql && codeql version && codeql pack install .github/codeql/start-ui-web-queries && codeql database create test-results/codeql/start-ui-web-db --language=javascript-typescript --source-root . --codescanning-config .github/codeql/codeql-local-extraction.yml --overwrite",
    "codeql:analyze": "mkdir -p test-results/codeql && db=test-results/codeql/start-ui-web-db; if [ ! -d \"$db\" ]; then echo \"CodeQL database not found at $db. Run pnpm codeql:db to create it before pnpm codeql:analyze.\" >&2; exit 1; fi; codeql version && codeql pack install .github/codeql/start-ui-web-queries && codeql database analyze \"$db\" .github/codeql/start-ui-web-queries/start-ui-web-codeql.qls --format=sarifv2.1.0 --output=test-results/codeql/start-ui-web.sarif --rerun",
    "codeql:test": "mkdir -p test-results/codeql && codeql version && codeql pack install .github/codeql/start-ui-web-queries && codeql test run .github/codeql/start-ui-web-queries/test",
    "security:audit": "pnpm audit --audit-level=high && pnpm security:tanstack && pnpm security:licenses && pnpm security:risk-register",
    "security:tanstack": "node scripts/check-tanstack-security.mjs",
    "security:licenses": "node scripts/check-license-compliance.mjs",
    "security:risk-register": "node scripts/check-risk-register.mjs",
    "knip:deps": "dotenv -e .env -e .env.example -- knip --include dependencies,unlisted --no-progress",
    "gen:build-info": "dotenv -- node ./run-jiti ./src/app/build-info/infrastructure/generate-build-info.ts",
    "gen:icons": "svgr --config-file src/platform/components/icons/svgr.config.cjs src/platform/components/icons/svg-sources && oxfmt src/platform/components/icons/generated",
    "test": "vitest run",
    "test:unit": "vitest run --project=unit",
    "test:property": "node scripts/run-property-tests.mjs",
    "test:browser": "vitest run --project=browser",
    "test:browser:visual": "vitest run --config vitest.visual.config.ts",
    "test:browser:visual:update": "pnpm test:browser:visual --update",
    "test:integration": "vitest run --project=integration",
    "test:affected": "tsx scripts/affected-tests.ts --run",
    "test:affected:list": "tsx scripts/affected-tests.ts",
    "test:jittest": "jittest catch",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "run-s test:mutation:runtime-config test:mutation:kernel test:mutation:shared",
    "test:mutation:fast": "run-s test:mutation:runtime-config:fast test:mutation:kernel:fast test:mutation:shared:fast",
    "test:mutation:dry": "run-s test:mutation:runtime-config:dry test:mutation:kernel:dry test:mutation:shared:dry",
    "test:mutation:fast:dry": "run-s test:mutation:runtime-config:fast:dry test:mutation:kernel:fast:dry test:mutation:shared:fast:dry",
    "test:mutation:runtime-config": "stryker run stryker.runtime-config.config.mjs",
    "test:mutation:runtime-config:fast": "cross-env STRYKER_FAST=1 stryker run stryker.runtime-config.config.mjs",
    "test:mutation:runtime-config:dry": "stryker run stryker.runtime-config.config.mjs --dryRunOnly",
    "test:mutation:runtime-config:fast:dry": "cross-env STRYKER_FAST=1 stryker run stryker.runtime-config.config.mjs --dryRunOnly",
    "test:mutation:kernel": "stryker run stryker.kernel.config.mjs",
    "test:mutation:kernel:fast": "cross-env STRYKER_FAST=1 stryker run stryker.kernel.config.mjs",
    "test:mutation:kernel:dry": "stryker run stryker.kernel.config.mjs --dryRunOnly",
    "test:mutation:kernel:fast:dry": "cross-env STRYKER_FAST=1 stryker run stryker.kernel.config.mjs --dryRunOnly",
    "test:mutation:shared": "stryker run stryker.shared-only.config.mjs",
    "test:mutation:shared:fast": "cross-env STRYKER_FAST=1 stryker run stryker.shared-only.config.mjs",
    "test:mutation:shared:dry": "stryker run stryker.shared-only.config.mjs --dryRunOnly",
    "test:mutation:shared:fast:dry": "cross-env STRYKER_FAST=1 stryker run stryker.shared-only.config.mjs --dryRunOnly",
    "test:e2e": "dotenv -e .env -e .env.example -- cross-env playwright test",
    "test:e2e:chromium": "pnpm test:e2e --project=chromium",
    "test:e2e:visual": "cross-env VITE_VISUAL_TEST=true pnpm test:e2e --project=chromium tests/e2e/visual",
    "test:e2e:visual:update": "pnpm test:e2e:visual --update-snapshots",
    "test:visual": "run-s test:browser:visual test:e2e:visual",
    "test:visual:update": "run-s test:browser:visual:update test:e2e:visual:update",
    "check": "run-p -n format:check lint lint:eslint typecheck depcruise architecture:graph:check check:test-layering semgrep security:audit knip:deps",
    "check:ci": "run-p -n format:check lint lint:eslint typecheck depcruise check:test-layering security:audit knip:deps",
    "verify": "pnpm check && pnpm test && pnpm build",
    "verify:task": "node scripts/task-verify.mjs",
    "test:ui": "vitest",
    "e2e:setup": "dotenv -e .env -e .env.example -- cross-env playwright test --project=setup",
    "e2e": "pnpm test:e2e",
    "e2e:ui": "pnpm test:e2e --ui",
    "dk:init": "docker compose --profile init up -d",
    "dk:start": "docker compose start",
    "dk:stop": "docker compose stop",
    "dk:clear": "docker compose down --volumes"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@bearstudio/ui-state": "1.1.0",
    "@better-upload/client": "3.0.19",
    "@bloodyowl/boxed": "^3.4.0",
    "@fontsource-variable/inter": "5.2.8",
    "@foresightjs/react": "^0.3.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.220.0",
    "@opentelemetry/core": "^2.9.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.220.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.220.0",
    "@opentelemetry/instrumentation": "^0.220.0",
    "@opentelemetry/instrumentation-document-load": "^0.65.0",
    "@opentelemetry/instrumentation-fetch": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-logs": "^0.220.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@opentelemetry/sdk-trace-web": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@sentry/tanstackstart-react": "^10.62.0",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "5.101.1",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.26",
    "@uidotdev/usehooks": "2.4.1",
    "boring-avatars": "2.0.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dotenv": "^17.4.2",
    "i18next": "26.3.6",
    "i18next-browser-languagedetector": "8.2.1",
    "input-otp": "1.4.2",
    "lucide-react": "1.24.0",
    "next-themes": "0.4.6",
    "nitro": "npm:nitro-nightly@3.0.1-20260501-164602-aee73f19",
    "react": "19.2.7",
    "react-day-picker": "10.0.1",
    "react-dom": "19.2.7",
    "react-error-boundary": "6.1.2",
    "react-i18next": "17.0.9",
    "react-merge-refs": "3.0.2",
    "react-textarea-autosize": "8.5.9",
    "react-use-disclosure": "12.0.1",
    "remeda": "2.39.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.2",
    "temporal-polyfill": "^1.0.1",
    "temporal-utils": "^1.0.1",
    "ts-pattern": "5.9.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.9.4",
    "@fast-check/vitest": "0.4.1",
    "@playwright/test": "1.61.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@softarc/sheriff-core": "^0.19.6",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@svgr/cli": "8.1.0",
    "@tailwindcss/postcss": "4.3.2",
    "@tanstack/devtools-vite": "0.8.1",
    "@tanstack/eslint-plugin-query": "5.101.2",
    "@tanstack/eslint-plugin-router": "1.162.0",
    "@tanstack/react-devtools": "0.10.8",
    "@tanstack/react-query-devtools": "5.101.2",
    "@tanstack/react-router-devtools": "1.167.0",
    "@types/node": "^24.12.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser": "4.1.10",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "babel-plugin-react-compiler": "1.0.0",
    "catching-jit-tests-vitest": "^0.4.0",
    "cross-env": "10.1.0",
    "dependency-cruiser": "^17.4.3",
    "dotenv-cli": "11.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-playwright": "^2.10.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-sonarjs": "4.1.0",
    "jiti": "2.7.0",
    "jscpd": "^4.2.4",
    "knip": "^6.26.0",
    "lefthook": "2.1.10",
    "npm-run-all": "4.1.5",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "playwright": "1.61.1",
    "react-cosmos": "^7.3.0",
    "react-cosmos-plugin-vite": "^7.3.0",
    "ts-plugin-sort-import-suggestions": "1.0.4",
    "tsx": "^4.23.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "vitest-browser-react": "2.2.0",
    "yaml": "2.9.0"
  },
  "resolutions": {
    "@types/node": "^24"
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "jscpd": {
    "threshold": 0,
    "reporters": [
      "markdown"
    ],
    "ignore": [
      "**/node_modules/**",
      "**/dist/**",
      "**/coverage/**",
      "**/tests/**",
      "**/*.json",
      "**/*.fixture.tsx",
      "**/*.test.ts",
      "**/*.css",
      "**/*.md"
    ],
    "absolute": false
  }
}
