{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "stryker": {
    // Per-module Stryker configs do not match knip's default stryker.config.* pattern.
    "config": ["stryker.*.config.mjs"],
  },
  "ignoreDependencies": [
    // Used by the retained platform avatar primitive, which is not currently reachable from an app entrypoint.
    "boring-avatars",
    // Manual copy-paste detection; configured via the "jscpd" key in package.json.
    "jscpd",
  ],
}
